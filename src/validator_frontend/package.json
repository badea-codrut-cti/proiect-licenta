    "@hono/vite-build": "^1.11.1",
    "@tailwindcss/vite": "^4.2.2",
    "autoprefixer": "^10.4.27",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
